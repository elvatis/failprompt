{
  "name": "@elvatis_com/failprompt",
  "version": "0.1.0",
  "description": "Parse CI failure logs and generate ready-to-paste AI prompts - in one command.",
  "type": "module",
  "bin": {
    "failprompt": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build && npm test",
    "test:watch": "vitest"
  },
  "keywords": [
    "ci",
    "github-actions",
    "gitlab-ci",
    "ai",
    "llm",
    "prompt",
    "cli"
  ],
  "author": "failprompt contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/elvatis/failprompt.git"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.0.0"
  }
}
